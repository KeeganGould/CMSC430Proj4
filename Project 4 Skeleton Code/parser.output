   11 list: '(' expressions ')'

   12 expressions: expressions ',' expression
   13            | expression

   14 body: BEGIN_ statement_ END ';'

   15 statement_: statement ';'
   16           | error ';'

   17 statement: expression
   18          | IF condition THEN statement_ elsif_clauses else_clause ENDIF
   19          | WHEN condition ',' expression ':' expression
   20          | SWITCH expression IS cases OTHERS ARROW statement ';' ENDSWITCH
   21          | FOLD direction operator list_choice ENDFOLD

   22 elsif_clauses: elsif_clauses elsif_clause
